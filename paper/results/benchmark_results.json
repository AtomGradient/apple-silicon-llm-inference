  "phase3_cross_device_sd": {
    "description": "Cross-device speculative decoding via GGML_RPC over 1 Gbps LAN. Target model (9B Q8) runs on M2 Ultra. Draft model (0.8B Q8) compute dispatched to remote no-BLAS rpc-server. k=4, T=0 greedy, 200 output tokens.",
    "target_machine": "M2_Ultra_192GB",
    "target_model": "Qwen3.5-9B Q8_0",
    "draft_model": "Qwen3.5-0.8B Q8_0",
    "k": 4,
    "network": "1 Gbps Ethernet LAN",
    "rpc_server_build": "GGML_RPC=ON, GGML_BLAS=OFF (no-BLAS; BLAS build caused abort and silent local fallback)",
    "investigation_notes": [
      "Initial BLAS-enabled rpc-server showed text=51.01, math=53.79 tok/s — effectively identical to local SD (51.10, 54.05).",
      "Acceptance rates for BLAS results (0.0232, 0.0325) were IDENTICAL to local baseline, confirming draft ran locally (BLAS/Metal backend conflict caused silent fallback to local M2 Ultra compute).",
      "No-BLAS rpc-server correctly routes draft to remote Metal GPU. M1 Max and M2 Pro produce numerically identical draft tokens (same Metal shader numerics at temp=0).",
      "RPC protocol overhead: ~51ms per draft token (vs 11.5ms local). Root cause is GGML_RPC issuing per-op RPC calls rather than batched forward passes."
    ],
    "results": [
      {
        "rpc_backend": "local",
        "rpc_server": "none",
        "note": "Baseline: draft compute on M2 Ultra itself",
        "by_prompt": [
          {"prompt": "code", "n_drafted": 680, "n_accept": 30, "accept_rate": 0.0441, "eff_tps": 55.80, "total_ms": 4084.56, "total_tokens": 228},
          {"prompt": "text", "n_drafted": 732, "n_accept": 17, "accept_rate": 0.0232, "eff_tps": 51.46, "total_ms": 4100.55, "total_tokens": 211},
          {"prompt": "math", "n_drafted": 708, "n_accept": 23, "accept_rate": 0.0325, "eff_tps": 54.09, "total_ms": 4085.90, "total_tokens": 221}
        ],
        "avg_eff_tps": 53.78,
        "vs_local_pct": 0.0
      },
      {
        "rpc_backend": "103_M1Max",
        "rpc_server": "192.168.0.103:50052",
        "remote_machine": "M1 Max 32GB (Apple M1 Max, 400 GB/s)",
        "note": "No-BLAS rpc-server. All 3 prompts completed. Draft compute on M1 Max Metal GPU via RPC.",
        "draft_tps_via_rpc": 16.0,
        "draft_tps_local_reference": 86.62,
        "rpc_overhead_per_token_ms": 51.0,
        "by_prompt": [
          {"prompt": "code", "n_drafted": 584, "n_accept": 54,  "accept_rate": 0.0925, "eff_tps": 11.15, "total_ms": 20436.0,  "total_tokens": 228},
          {"prompt": "text", "n_drafted": 240, "n_accept": 140, "accept_rate": 0.5833, "eff_tps": 11.18, "total_ms": 18867.9,  "total_tokens": 211},
          {"prompt": "math", "n_drafted": 256, "n_accept": 136, "accept_rate": 0.5313, "eff_tps": 11.26, "total_ms": 19631.7,  "total_tokens": 221}
        ],
        "avg_eff_tps": 11.20,
        "vs_local_pct": -79.2
      },
      {
        "rpc_backend": "104_M2Pro",
        "rpc_server": "192.168.0.104:50052",
        "remote_machine": "M2 Pro 32GB (Apple M2 Pro, 200 GB/s)",
        "note": "No-BLAS rpc-server. All 3 prompts completed. Draft compute on M2 Pro Metal GPU via RPC.",
        "draft_tps_via_rpc": 14.2,
        "draft_tps_local_reference": 62.94,
        "rpc_overhead_per_token_ms": 57.0,
        "by_prompt": [
          {"prompt": "code", "n_drafted": 584, "n_accept": 54,  "accept_rate": 0.0925, "eff_tps": 9.66, "total_ms": 23603.1,  "total_tokens": 228},
          {"prompt": "text", "n_drafted": 240, "n_accept": 140, "accept_rate": 0.5833, "eff_tps": 8.77, "total_ms": 24059.2,  "total_tokens": 211},
          {"prompt": "math", "n_drafted": 256, "n_accept": 136, "accept_rate": 0.5313, "eff_tps": 9.71, "total_ms": 22772.2,  "total_tokens": 221}
        ],
        "avg_eff_tps": 9.38,
        "vs_local_pct": -82.6
      }
    ],
    "key_findings": {
      "overhead_vs_local": "~79-83% throughput reduction on Gigabit LAN (no-BLAS, correct measurement)",
      "rpc_overhead_root_cause": "GGML_RPC issues per-op RPC calls; each draft token incurs ~51-57ms overhead vs 11.5ms local — not network bandwidth limited",
      "blas_fallback_warning": "BLAS-enabled rpc-server silently falls back to local compute; measurements from BLAS builds are invalid for cross-device evaluation",
      "acceptance_rate_note": "Remote Metal GPU (M1 Max, M2 Pro) produces different tokens from local M2 Ultra Metal at temp=0 (FP arithmetic differences), but M1 Max and M2 Pro produce identical tokens (same Metal shader numerics)",
      "conclusion": "GGML_RPC cross-device SD is not currently viable for production use. RPC protocol overhead (~51-57ms/token) dominates. Purpose-built streaming protocol required."
    }
  }
}
